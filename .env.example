# =============================================================================
# Lucy — Environment Variables
# =============================================================================
# Copy to .env and fill in required values.

# --- Required ----------------------------------------------------------------

# OpenRouter API key — used by Pi SDK for LLM calls
OPENROUTER_API_KEY=

# Model identifier for the Pi agent (e.g. openrouter/anthropic/claude-sonnet-4)
PI_BRIDGE_MODEL=

# --- Optional (have defaults) ------------------------------------------------

# Gateway HTTP port (default: 3080)
# PORT=3080

# Unix socket path for pi-bridge ↔ gateway IPC (default: /tmp/lucy-pi.sock)
# PI_BRIDGE_SOCKET=/tmp/lucy-pi.sock

# CORS allowed origin (default: *)
# CORS_ORIGIN=*

# Pi SDK data directory — sessions, config, etc. (default: ~/.pi/agent)
# Set in Docker to persist under .agents (e.g. .agents/pi)
# PI_CODING_AGENT_DIR=.agents/pi

# --- Optional (enable features) ----------------------------------------------

# Gateway API key — protects /api/* routes with Bearer token auth
# LUCY_API_KEY=

# Pi SDK provider override (if not using OpenRouter default)
# PI_BRIDGE_PROVIDER=

# Path to system prompt file appended to Pi's default prompt (default: prompt.md)
# PI_BRIDGE_PROMPT=prompt.md

# --- Telegram integration (all required if enabling Telegram) ----------------

# Telegram bot token from @BotFather
# TELEGRAM_BOT_TOKEN=

# Single Telegram chat ID to allow
# TELEGRAM_CHAT_ID=123456789
