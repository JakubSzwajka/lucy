# =============================================================================
# Lucy — Environment Variables
# =============================================================================
# Copy to .env and fill in required values.

# --- Required ----------------------------------------------------------------

# OpenRouter API key — used by Pi SDK for LLM calls
OPENROUTER_API_KEY=

# Model identifier for the Pi agent (e.g. openrouter/anthropic/claude-sonnet-4)
PI_BRIDGE_MODEL=

# --- Optional (have defaults) ------------------------------------------------

# Gateway HTTP port (default: 3080)
# PORT=3080

# Unix socket path for pi-bridge ↔ gateway IPC (default: /tmp/lucy-pi.sock)
# PI_BRIDGE_SOCKET=/tmp/lucy-pi.sock

# CORS allowed origin (default: *)
# CORS_ORIGIN=*

# Data directory for memory extension (default: ~/.agents-data)
# Local dev: .data  |  Docker/Railway: /data
AGENTS_DATA_DIR=.data

# Pi SDK data directory — sessions, config, etc. (default: ~/.pi/agent)
# Set in Docker/Railway to persist under the mounted volume.
# PI_CODING_AGENT_DIR=

# --- Optional (enable features) ----------------------------------------------

# Gateway API key — protects /api/* routes with Bearer token auth
# LUCY_API_KEY=

# Pi SDK provider override (if not using OpenRouter default)
# PI_BRIDGE_PROVIDER=

# Path to system prompt file appended to Pi's default prompt (default: prompt.md)
# PI_BRIDGE_PROMPT=prompt.md

# --- WhatsApp integration (all required if enabling WhatsApp) ----------------

# Meta WhatsApp phone number ID
# WHATSAPP_PHONE_NUMBER_ID=

# Meta WhatsApp API token (use System User token for non-expiring)
# WHATSAPP_API_TOKEN=

# Webhook verification token
# WHATSAPP_VERIFY_TOKEN=

# Comma-separated allowed phone numbers
# WHATSAPP_ALLOWED_NUMBERS=+1234567890,+0987654321

# --- Telegram integration (all required if enabling Telegram) ----------------

# Telegram bot token from @BotFather
# TELEGRAM_BOT_TOKEN=

# Comma-separated allowed chat IDs
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
