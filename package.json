{
  "name": "lucy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/gateway/core/src/index.ts",
    "start": "tsx src/gateway/core/src/index.ts",
    "build:webui": "cd src/gateway/extensions/webui && npx vite build",
