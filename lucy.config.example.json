{
  "runtime": {
    "model": "openrouter/anthropic/claude-sonnet-4",
    "compaction": {
      "enabled": true,
      "reserveTokens": 16384,
      "keepRecentTokens": 20000
    },
    "session": {
      "persist": true,
      "resume": true
    },
    "extensions": []
  },
  "gateway": {
    "apiKey": "YOUR_API_KEY"
  },
  "whatsapp": {
    "phoneNumberId": "YOUR_PHONE_NUMBER_ID",
    "verifyToken": "YOUR_VERIFY_TOKEN",
    "allowedNumbers": ["YOUR_PHONE_NUMBER"]
  }
}
