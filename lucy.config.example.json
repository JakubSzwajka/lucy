{
  "agents-runtime": {
    "model": "anthropic/claude-sonnet-4-20250514",
    "compaction": {
      "enabled": true,
      "reserveTokens": 16384,
      "keepRecentTokens": 20000
    },
    "session": {
      "persist": true,
      "resume": true
    },
    "extensions": [
      "agents-memory"
    ]
  },
  "plugins": [
    {
      "package": "agents-plugin-whatsapp",
      "config": {}
    }
  ],
  "agents-gateway-http": {
    "allowedModels": [
      "anthropic/*"
    ],
    "auth": {
      "apiKey": ""
    }
  }
}
