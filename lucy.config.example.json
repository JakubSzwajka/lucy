{
  "plugins": [
    {
      "package": "agents-memory",
      "config": {
        "modelId": "openai/gpt-4o-mini"
      }
    },
    {
      "package": "agents-plugin-whatsapp",
      "config": {
        "phoneNumberId": "YOUR_PHONE_NUMBER_ID",
        "verifyToken": "YOUR_VERIFY_TOKEN",
        "allowedNumbers": ["1234567890"]
      }
    },
    {
      "package": "agents-webui"
    },
    {
      "package": "agents-landing-page"
    }
  ],
  "agents-runtime": {
    "compaction": {
      "windowSize": 50
    }
  },
  "agents-gateway-http": {
    "allowedModels": ["anthropic/*", "openai/*"],
    "auth": {                                  
      "apiKey": "your-secret-key"
    }
  }
}
