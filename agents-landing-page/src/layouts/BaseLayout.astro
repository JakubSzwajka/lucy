---
const { title = "Lucy", description = "Agent infrastructure for shipping autonomous systems." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe6;
        --surface: rgba(255, 252, 246, 0.78);
        --surface-strong: #fffaf2;
        --text: #1e1d1a;
        --muted: #5d584d;
        --border: rgba(30, 29, 26, 0.1);
        --accent: #0d6b5d;
        --accent-strong: #084d43;
        --shadow: 0 24px 80px rgba(42, 36, 27, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "IBM Plex Sans", "Avenir Next", Avenir, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.8), transparent 40%),
          linear-gradient(180deg, #f7f2e8 0%, #efe6d8 100%);
        color: var(--text);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page-shell {
        width: min(1120px, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 1rem 0 4rem;
      }

      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
        gap: 2rem;
        align-items: center;
      }

      .hero-copy {
        padding: 4rem 0;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.85rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.55);
        color: var(--muted);
        font-size: 0.92rem;
        letter-spacing: 0.02em;
      }

      h1 {
        margin: 1.25rem 0 1rem;
        font-size: clamp(3rem, 8vw, 6.4rem);
        line-height: 0.94;
        letter-spacing: -0.06em;
      }

      .lede {
        max-width: 40rem;
        font-size: clamp(1.08rem, 2vw, 1.28rem);
        line-height: 1.7;
        color: var(--muted);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3.4rem;
        padding: 0 1.3rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 600;
      }

      .button-primary {
        background: var(--accent);
        color: #f8fffd;
      }

      .button-secondary {
        background: rgba(255, 255, 255, 0.5);
        border-color: var(--border);
      }

      .panel {
        position: relative;
        overflow: hidden;
        padding: 1.4rem;
        border: 1px solid var(--border);
        border-radius: 28px;
        background: var(--surface);
        box-shadow: var(--shadow);
        backdrop-filter: blur(20px);
      }

      .stack {
        display: grid;
        gap: 1rem;
      }

      .mini-label {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      .stat {
        display: grid;
        gap: 0.25rem;
        padding: 1rem 0 0;
        border-top: 1px solid var(--border);
      }

      .stat strong {
        font-size: 2rem;
        letter-spacing: -0.04em;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      .card {
        padding: 1rem;
        border-radius: 22px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
      }

      .card h2,
      .card h3,
      .panel h2 {
        margin: 0;
        font-size: 1rem;
      }

      .card p,
      .panel p,
      .panel li {
        color: var(--muted);
        line-height: 1.6;
      }

      ul {
        margin: 0.75rem 0 0;
        padding-left: 1.1rem;
      }

      footer {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 1.5rem;
        color: var(--muted);
        font-size: 0.94rem;
      }

      @media (max-width: 900px) {
        .hero {
          min-height: auto;
          grid-template-columns: 1fr;
          padding-top: 2rem;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <main class="page-shell">
      <slot />
    </main>
  </body>
</html>
