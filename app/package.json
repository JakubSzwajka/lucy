    "typeorm": "npx typeorm-ts-node-commonjs",
    "migrate": "npx typeorm-ts-node-commonjs migration:run -d ./src/db.ts",
    "migrate:generate": "npx typeorm-ts-node-commonjs migration:generate -d ./src/db.ts"
