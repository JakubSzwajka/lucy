{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "outDir": "dist",
    "baseUrl": "./",
    "rootDir": ".",
    "incremental": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/lucy/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "web"]
}
