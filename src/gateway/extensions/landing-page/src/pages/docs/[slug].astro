---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

// Build sidebar nav from full collection
const allDocs = await getCollection("docs");
allDocs.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const sectionOrder = ["General", "Runtime", "Gateway", "Reference"];
const grouped = new Map<string, typeof allDocs>();
for (const d of allDocs) {
  const section = d.data.section ?? "General";
  if (!grouped.has(section)) grouped.set(section, []);
  grouped.get(section)!.push(d);
}
const sections = [...grouped.entries()].sort(
  (a, b) => (sectionOrder.indexOf(a[0]) ?? 99) - (sectionOrder.indexOf(b[0]) ?? 99)
);

const currentSlug = doc.id;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{doc.data.title} - Lucy Docs</title>
    <meta name="description" content={doc.data.title} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg: hsl(220, 15%, 7%);
        --surface: hsl(220, 13%, 10%);
        --border: hsl(220, 13%, 14%);
        --text: hsl(214, 32%, 91%);
        --muted: hsl(215, 16%, 40%);
        --glow: #c8e64a;
        --glow-dim: rgba(200, 230, 74, 0.06);
        --sidebar-w: 240px;
      }

      html {
        background: var(--bg);
        color: var(--text);
        font-family: "Inter", sans-serif;
      }

      body {
        min-height: 100dvh;
      }

      /* ── Layout ── */
      .layout {
        display: flex;
        min-height: 100dvh;
        max-width: 1200px;
        margin: 0 auto;
      }

      /* ── Sidebar ── */
      .sidebar {
        width: var(--sidebar-w);
        flex-shrink: 0;
        border-right: 1px solid var(--border);
        padding: 2rem 1.25rem;
        position: sticky;
        top: 0;
        height: 100dvh;
        overflow-y: auto;
      }

      .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        margin-bottom: 2rem;
      }

      .sidebar-logo img {
        width: 24px;
        height: 24px;
      }

      .sidebar-logo span {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.02em;
      }

      .sidebar-logo .docs-label {
        color: var(--muted);
        font-weight: 400;
      }

      .sidebar-section {
        margin-bottom: 1.5rem;
      }

      .sidebar-section-title {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.5rem;
        padding-left: 0.5rem;
      }

      .sidebar-links {
        display: flex;
        flex-direction: column;
        gap: 1px;
      }

      .sidebar-link {
        display: block;
        font-size: 0.82rem;
        font-weight: 400;
        color: var(--muted);
        text-decoration: none;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        transition: color 0.15s, background 0.15s;
      }

      .sidebar-link:hover {
        color: var(--text);
        background: var(--glow-dim);
      }

      .sidebar-link.active {
        color: var(--glow);
        background: rgba(200, 230, 74, 0.08);
      }

      /* ── Main content ── */
      .main {
        flex: 1;
        min-width: 0;
        padding: 3rem 3rem 4rem;
        max-width: 860px;
      }

      .doc-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
      }

      .doc-title {
        font-family: "Inter", sans-serif;
        font-size: clamp(1.4rem, 3.5vw, 1.8rem);
        font-weight: 600;
        color: var(--text);
        line-height: 1.3;
      }

      .doc-section-badge {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: 0.5rem;
      }

      /* ── Prose ── */
      .prose {
        line-height: 1.7;
        font-size: 0.95rem;
      }

      .prose :global(h1) {
        display: none;
      }

      .prose :global(h2) {
        font-family: "Inter", sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text);
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        letter-spacing: -0.01em;
      }

      .prose :global(h3) {
        font-family: "Inter", sans-serif;
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text);
        margin-top: 2rem;
        margin-bottom: 0.5rem;
      }

      .prose :global(h4) {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }

      .prose :global(p) {
        color: var(--text);
        margin-bottom: 1rem;
        opacity: 0.9;
      }

      .prose :global(ul),
      .prose :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
      }

      .prose :global(li) {
        color: var(--text);
        opacity: 0.9;
        margin-bottom: 0.35rem;
      }

      .prose :global(li)::marker {
        color: var(--muted);
      }

      .prose :global(strong) {
        color: var(--text);
        font-weight: 600;
      }

      .prose :global(em) {
        color: var(--muted);
        font-style: italic;
      }

      .prose :global(code) {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85em;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.15em 0.4em;
        color: var(--glow);
      }

      .prose :global(pre) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.25rem;
        overflow-x: auto;
      }

      .prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.8rem;
        color: var(--text);
        line-height: 1.6;
      }

      .prose :global(blockquote) {
        border-left: 2px solid var(--glow);
        padding-left: 1rem;
        margin-bottom: 1rem;
        color: var(--muted);
        font-style: italic;
      }

      .prose :global(a) {
        color: var(--glow);
        text-decoration: none;
        opacity: 0.8;
        transition: opacity 0.2s;
      }

      .prose :global(a:hover) {
        opacity: 1;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
      }

      .prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.25rem;
        font-size: 0.85rem;
      }

      .prose :global(th) {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: left;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border);
      }

      .prose :global(td) {
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        opacity: 0.9;
      }

      /* ── Mobile ── */
      @media (max-width: 768px) {
        .layout {
          flex-direction: column;
        }
        .sidebar {
          width: 100%;
          height: auto;
          position: relative;
          border-right: none;
          border-bottom: 1px solid var(--border);
          padding: 1.5rem 1.25rem 1rem;
        }
        .main {
          padding: 2rem 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <nav class="sidebar">
        <a href="/docs/" class="sidebar-logo">
          <img src="/logo.png" alt="Lucy" />
          <span>lucy <span class="docs-label">docs</span></span>
        </a>
        {sections.map(([sectionName, docs]) => (
          <div class="sidebar-section">
            <div class="sidebar-section-title">{sectionName}</div>
            <div class="sidebar-links">
              {docs.map((d) => (
                <a
                  href={`/docs/${d.id}/`}
                  class:list={["sidebar-link", { active: d.id === currentSlug }]}
                >
                  {d.data.title}
                </a>
              ))}
            </div>
          </div>
        ))}
      </nav>
      <main class="main">
        <div class="doc-header">
          <h1 class="doc-title">{doc.data.title}</h1>
          <div class="doc-section-badge">{doc.data.section}</div>
        </div>
        <div class="prose">
          <Content />
        </div>
      </main>
    </div>
  </body>
</html>
