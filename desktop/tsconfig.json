{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "app",
    "rootDir": "main",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["main/**/*.ts"],
  "exclude": ["node_modules", "renderer", "app", "dist"]
}
